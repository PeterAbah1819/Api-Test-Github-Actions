      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Save the ID in the environment variable and call it in a get request",
              "const json = pm.response.json();",
              "pm.environment.set(\"New-productId\", json.id);",
              "",
              "",
              "//Confirm the response code is 200",
              "    pm.test(\"Status code is 200\", function () {",
              "        pm.response.to.have.status(200);",
              "    });",
              "",
              "",
              "//Confirm the response body contains a number",
              "pm.test(\"Body contains string\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"5000\");",
              "});",
              "",
              "",
              "//Confirm the response body contains text",
              "pm.test(\"Body contains string\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"TT G5\");",
              "});",
              "",
              "//Confirm response time is less than 1100ms",
              "pm.test(\"Response time is less than 900ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1100);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// List of phone brands",
              "const phoneMakes = [\"Apple\", \"Samsung\", \"Google\", \"OnePlus\", \"Xiaomi\", \"Sony\", \"Huawei\", \"Motorola\"];",
              "",
              "// Model series per brand",
              "const modelSeries = {",
              "    \"Apple\": [\"iPhone\"],",
              "    \"Samsung\": [\"Galaxy S\", \"Galaxy A\", \"Galaxy Z\"],",
              "    \"Google\": [\"Pixel\"],",
              "    \"OnePlus\": [\"Nord\", \"Pro\"],",
              "    \"Xiaomi\": [\"Mi\", \"Redmi\", \"Poco\"],",
              "    \"Sony\": [\"Xperia\"],",
              "    \"Huawei\": [\"P\", \"Mate\"],",
              "    \"Motorola\": [\"Moto G\", \"Moto Edge\"]",
              "};",
              "",
              "// Generate random phone make",
              "const randomMake = phoneMakes[Math.floor(Math.random() * phoneMakes.length)];",
              "",
              "// Generate random phone model (make + series + random number)",
              "const series = modelSeries[randomMake];",
              "const randomSeries = series[Math.floor(Math.random() * series.length)];",
              "const randomNumber = Math.floor(Math.random() * 20) + 1;",
              "const randomModel = `${randomMake} ${randomSeries} ${randomNumber}`;",
              "",
              "// Generate valid 15-digit IMEI with Luhn check digit",
              "function generateIMEI() {",
              "    // Generate first 14 digits (TAC + Serial)",
              "    let imei = \"\";",
              "    for (let i = 0; i < 14; i++) {",
              "        imei += Math.floor(Math.random() * 10).toString();",
              "    }",
              "    ",
              "    // Calculate Luhn check digit",
              "    let sum = 0;",
              "    for (let i = 0; i < 14; i++) {",
              "        let digit = parseInt(imei[i]);",
              "        if (i % 2 === 1) {",
              "            digit *= 2;",
              "            if (digit > 9) {",
              "                digit = Math.floor(digit / 10) + (digit % 10);",
              "            }",
              "        }",
              "        sum += digit;",
              "    }",
              "    const checkDigit = (10 - (sum % 10)) % 10;",
              "    ",
              "    return imei + checkDigit.toString();",
              "}",
              "",
              "const randomIMEI = generateIMEI();",
              "",
              "// Set collection variables",
              "pm.environment.set(\"RandomPhoneMake\", randomMake);",
              "pm.environment.set(\"RandomPhoneModel\", randomModel);",
              "pm.environment.set(\"RandomIMEI\", randomIMEI);",
              "",
              "console.log(\"Generated Phone Make:\", randomMake);",
              "console.log(\"Generated Phone Model:\", randomModel);",
              "console.log(\"Generated IMEI:\", randomIMEI);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
