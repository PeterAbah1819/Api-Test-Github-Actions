    {
      "name": "List all products - Correct URL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Confirm the response code is 200",
              "    pm.test(\"Status code is 200\", function () {",
              "        pm.response.to.have.status(200);",
              "    });",
              "",
              "//Confirm the response body contains Google Pixel",
              "pm.test(\"Body contains string\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"Google Pixel 6 Pro\");",
              "});",
              "",
              "",
              "//Confirm the response body contains a colour",
              "pm.test(\"Body contains string\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"Brown\");",
              "});",
              "",
              "",
              "//Confirm the response body contains ID",
              "pm.test(\"Body contains string\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"6\");",
              "});",
              "",
              "//Confirm response time is less than 1100ms",
              "pm.test(\"Response time is less than 900ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1100);",
              "});",
              "",
              "",
              "",
              "//Save the product ID for ID 6 in the collection variable to make it reusable in the next request",
              "// Parse the response body",
              "const response = pm.response.json();",
              "",
              "// Find the product with id \"6\"",
              "const product = response.find(item => item.name === \"Samsung Galaxy Z Fold2\");",
              "",
              "// Save the id to a Postman environment/collection variable",
              "if (product) {",
              "    pm.environment.set(\"productId\", product.id);",
              "    console.log(\"Saved product ID:\", product.id);",
              "} else {",
              "    console.log(\"Product with id 6 not found\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
